# ── Sanity ────────────────────────────────────────────────────────────────
# Create a project at https://sanity.io/manage, then copy values here.
# The site runs with fallback content when these are unset — fill them in
# when you're ready to manage content through the Studio.

NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Optional: secret for the /api/revalidate webhook.
# Add the same value in Sanity's webhook "Secret" field.
SANITY_REVALIDATE_SECRET=
